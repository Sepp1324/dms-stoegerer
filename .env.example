# --- Django ---
# In Produktion (DJANGO_DEBUG=false) MUSS ein echtes Secret gesetzt sein –
# sonst verweigert das Backend den Start (Fail-closed).
DJANGO_SECRET_KEY=change-me-in-production
DJANGO_DEBUG=true
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1
# Kommagetrennte Origins für die SPA (CORS/CSRF)
DJANGO_CORS_ORIGINS=http://localhost:5173

# --- HTTPS-Härtung (greift nur bei DJANGO_DEBUG=false) ---
# secure-Cookies + HSTS sind dann per Default an. Optional übersteuerbar:
# SESSION_COOKIE_SECURE=true
# CSRF_COOKIE_SECURE=true
# SECURE_SSL_REDIRECT=false            # Traefik leitet i. d. R. schon am Edge um
# SECURE_HSTS_SECONDS=31536000
# SECURE_HSTS_INCLUDE_SUBDOMAINS=false # AUS: Parent-Domain wird geteilt
# SECURE_HSTS_PRELOAD=false

# --- Datenbank (PostgreSQL) ---
POSTGRES_DB=dms
POSTGRES_USER=dms
POSTGRES_PASSWORD=dms
POSTGRES_HOST=db
POSTGRES_PORT=5432

# --- Redis / Celery ---
REDIS_URL=redis://redis:6379/0
# Beat-Intervalle in Sekunden (periodische Aufgaben; benötigt `celery beat`).
MAIL_FETCH_INTERVAL=300
CONSUME_SCAN_INTERVAL=120

# --- E-Mail-Ingestion (IMAP, Stufe 3) ---
# Host/Port/User/Ordner werden im Django-Admin ("E-Mail-Konto") gepflegt.
# Das Passwort NICHT hier committen: am Konto "password_env" auf den Namen
# dieser Variable setzen (App-Passwort verwenden).
IMAP_PASSWORD=

# --- Datei-Ablage ---
# Wurzelverzeichnis der revisionssicheren Ablage im Container/Volume
DMS_DATA_DIR=/data

# --- AI-Anbindung ---
# Provider: anthropic | ollama | openai | disabled
AI_PROVIDER=anthropic
# Modell je Provider. Default claude-opus-4-8 (beste Qualität).
# Für kostengünstige Massen-Klassifizierung: claude-haiku-4-5
AI_MODEL=claude-opus-4-8
# Für anthropic/openai: API-Key. Für ollama leer lassen.
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
# Für ollama: Basis-URL des lokalen Servers
OLLAMA_BASE_URL=http://host.docker.internal:11434
